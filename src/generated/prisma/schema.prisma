// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String   @id @default(uuid())
  nombre     String
  email      String   @unique
  password   String
  role       String   @default("ALMACENISTA")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("Usuarios")
}

model Muestra {
  id              String          @id @default(uuid())
  nombre          String
  existencias     Int
  umbral_minimo   Int
  created_at      DateTime        @default(now())
  entregas        Entrega[]
  logs_inventario LogInventario[]

  @@map("Muestras")
}

model Visitador {
  id                 String    @id @default(uuid())
  nombre             String
  zona               String
  muestras_asignadas Int
  created_at         DateTime  @default(now())
  entregas           Entrega[]

  @@map("Visitadores")
}

model Entrega {
  id               String    @id @default(uuid())
  muestra_id       String
  muestra          Muestra   @relation(fields: [muestra_id], references: [id])
  visitador_id     String
  visitador        Visitador @relation(fields: [visitador_id], references: [id])
  nombre_visitador String?
  nombre_muestra   String?
  cantidad         Int
  fecha            DateTime  @db.Date
  hora             DateTime  @db.Time
  estado           String?
  created_at       DateTime  @default(now())

  @@map("Entregas")
}

model LogInventario {
  id              String   @id @default(uuid())
  muestra_id      String?
  muestra         Muestra? @relation(fields: [muestra_id], references: [id])
  tipo_movimiento String
  cantidad        Int
  descripcion     String?
  usuario_id      String?
  created_at      DateTime @default(now())

  @@map("Logs_Inventario")
}
